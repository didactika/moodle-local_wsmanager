<div class="servicemanager-import-page">
    <div class="mb-4">
        <a href="{{backurl}}" class="btn btn-secondary">
            <i class="fa fa-arrow-left mr-2"></i>{{#str}}back, local_servicemanager{{/str}}
        </a>
    </div>

    <div class="alert alert-info">
        <h5><i class="fa fa-info-circle mr-2"></i>{{#str}}import_info_title, local_servicemanager{{/str}}</h5>
        <p>{{#str}}import_info_text, local_servicemanager{{/str}}</p>
        <ul>
            <li>{{#str}}import_info_yaml, local_servicemanager{{/str}}</li>
            <li>{{#str}}import_info_zip, local_servicemanager{{/str}}</li>
        </ul>
        <p>
            <a href="{{docurl}}" class="text-info font-weight-bold">
                <i class="fa fa-book mr-1"></i>{{#str}}view_documentation, local_servicemanager{{/str}}
            </a>
        </p>
    </div>

    <div class="import-form-container">
        {{{formhtml}}}
    </div>
</div>

{{!
    @template local_servicemanager/dashboard

    Dashboard template for Web Service Manager.

    Context variables required:
    * schemas - Array of schema objects
    * has_schemas - Boolean
    * import_url - URL to import page
    * can_manage - Boolean
    * has_pagination - Boolean
    * pagination - Pagination data object
    * has_filters - Boolean indicating if filters are applied
    * filter_count - Number of active filters
}}

<div class="servicemanager-dashboard">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">{{#str}}dashboard, local_servicemanager{{/str}}</h2>
        <div class="btn-toolbar">
            {{#can_manage}}
            <a href="{{import_url}}" class="btn btn-primary">
                <i class="fa fa-download mr-2"></i>{{#str}}import_schemas, local_servicemanager{{/str}}
            </a>
            {{/can_manage}}
            {{#has_any_schemas}}
            <a href="{{export_all_url}}" class="btn btn-outline-secondary ml-2">
                <i class="fa fa-file-archive-o mr-2"></i>{{#str}}export_all, local_servicemanager{{/str}}
            </a>
            {{/has_any_schemas}}
        </div>
    </div>

    {{! Web Service Status Panel — accordion }}
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center"
             data-toggle="collapse" data-target="#ws-status-details"
             aria-expanded="false" aria-controls="ws-status-details"
             style="cursor: pointer;">
            <div>
                <i class="fa fa-plug mr-2"></i>
                <strong>{{#str}}ws_status_panel, local_servicemanager{{/str}}</strong>
            </div>
            <div class="d-flex align-items-center">
                <span class="badge {{ws_status.status_class}} mr-2">
                    <i class="fa fa-circle mr-1"></i>{{ws_status.status_label}}
                </span>
                <i class="fa fa-chevron-down"></i>
            </div>
        </div>
        <div id="ws-status-details" class="collapse">
            <div class="card-body py-3">
                <div class="row">
                    <div class="col-md-4 border-right">
                        <div class="text-muted small text-uppercase mb-1">
                            {{#str}}ws_services_label, local_servicemanager{{/str}}
                        </div>
                        <span class="{{ws_status.ws_enabled_class}} font-weight-bold">
                            <i class="fa fa-circle mr-1"></i>{{ws_status.ws_enabled_label}}
                        </span>
                    </div>
                    <div class="col-md-4 pl-4 border-right">
                        <div class="text-muted small text-uppercase mb-1">
                            {{#str}}ws_protocols_label, local_servicemanager{{/str}}
                            ({{ws_status.enabled_protocols_count}})
                        </div>
                        {{#ws_status.protocols}}
                        <span class="badge {{badge_class}} mr-1">{{name}}</span>
                        {{/ws_status.protocols}}
                    </div>
                    <div class="col-md-4 pl-4">
                        <div class="text-muted small text-uppercase mb-1">
                            {{#str}}ws_health_label, local_servicemanager{{/str}}
                        </div>
                        <div>
                            <span class="text-success mr-3">
                                <i class="fa fa-circle mr-1"></i>{{ws_status.health_healthy}}
                            </span>
                            <span class="text-warning mr-3">
                                <i class="fa fa-circle mr-1"></i>{{ws_status.health_warning}}
                            </span>
                            <span class="text-danger">
                                <i class="fa fa-circle mr-1"></i>{{ws_status.health_critical}}
                            </span>
                        </div>
                        <div class="text-muted small mt-1">
                            {{#str}}status_healthy, local_servicemanager{{/str}} ·
                            {{#str}}status_warning, local_servicemanager{{/str}} ·
                            {{#str}}status_critical, local_servicemanager{{/str}}
                        </div>
                    </div>
                </div>
            </div>
            {{#ws_status.can_manage}}
            <div class="card-footer py-2 text-muted small">
                <a href="{{ws_status.overview_url}}" target="_blank">
                    {{#str}}ws_overview_link, local_servicemanager{{/str}}
                    <i class="fa fa-external-link ml-1"></i>
                </a>
                <span class="mx-2">·</span>
                <a href="{{ws_status.protocols_url}}" target="_blank">
                    {{#str}}ws_manage_protocols_link, local_servicemanager{{/str}}
                    <i class="fa fa-external-link ml-1"></i>
                </a>
            </div>
            {{/ws_status.can_manage}}
        </div>
    </div>

    <!-- Header Row with Filter on Right -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <!-- Left side: Bulk actions (visible when items selected) -->
        <div class="d-flex align-items-center">
            {{#can_manage}}
            <div class="bulk-actions d-none" id="bulk-actions-bar">
                <span class="selected-count font-weight-bold mr-2"><span id="selected-count">0</span> {{#str}}selected, local_servicemanager{{/str}}</span>
                <button type="submit" form="bulk-form" name="action" value="enable" class="btn btn-sm btn-success bulk-btn-enable mr-1" style="display:none">
                    <i class="fa fa-check mr-1"></i>{{#str}}bulk_enable, local_servicemanager{{/str}}
                </button>
                <button type="submit" form="bulk-form" name="action" value="disable" class="btn btn-sm btn-secondary bulk-btn-disable mr-1" style="display:none">
                    <i class="fa fa-ban mr-1"></i>{{#str}}bulk_disable, local_servicemanager{{/str}}
                </button>
                <button type="submit" form="bulk-form" name="action" value="export" class="btn btn-sm btn-info mr-1">
                    <i class="fa fa-download mr-1"></i>{{#str}}bulk_export, local_servicemanager{{/str}}
                </button>
                <button type="submit" form="bulk-form" name="action" value="delete" class="btn btn-sm btn-danger" onclick="return confirm('{{#str}}bulk_delete_confirm, local_servicemanager{{/str}}');">
                    <i class="fa fa-trash mr-1"></i>{{#str}}bulk_delete, local_servicemanager{{/str}}
                </button>
            </div>
            {{/can_manage}}
            {{^can_manage}}
            <div></div>
            {{/can_manage}}
        </div>

        <!-- Right side: Filter Dropdown -->
        <div class="dropdown">
            <button class="btn btn-outline-secondary dropdown-toggle" 
                    type="button" id="filtersDropdown" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <i class="fa fa-filter mr-1"></i>
                {{#str}}filters, local_servicemanager{{/str}}
                {{#has_filters}}
                <span class="badge badge-primary ml-1">{{filter_count}}</span>
                {{/has_filters}}
            </button>
            <div class="dropdown-menu dropdown-menu-right p-3" style="min-width: 280px;" aria-labelledby="filtersDropdown" onclick="event.stopPropagation();">
                <form method="get" action="" id="filter-form">
                    <!-- Status -->
                    <div class="mb-3">
                        <label for="status">{{#str}}filter_status, local_servicemanager{{/str}}</label>
                        <select name="status" id="status" class="form-control">
                            <option value="">{{#str}}filter_status_all, local_servicemanager{{/str}}</option>
                            <option value="healthy" {{#filter_status_healthy}}selected{{/filter_status_healthy}}>{{#str}}status_healthy, local_servicemanager{{/str}}</option>
                            <option value="warning" {{#filter_status_warning}}selected{{/filter_status_warning}}>{{#str}}status_warning, local_servicemanager{{/str}}</option>
                            <option value="critical" {{#filter_status_critical}}selected{{/filter_status_critical}}>{{#str}}status_critical, local_servicemanager{{/str}}</option>
                        </select>
                    </div>
                    
                    <!-- Per page -->
                    <div class="mb-3">
                        <label for="perpage">{{#str}}filter_per_page, local_servicemanager{{/str}}</label>
                        <select name="perpage" id="perpage" class="form-control">
                            {{#perpage_options}}
                            <option value="{{value}}" {{#selected}}selected{{/selected}}>{{value}}</option>
                            {{/perpage_options}}
                        </select>
                    </div>
                    
                    <!-- Name search -->
                    <div class="mb-3">
                        <label for="name">{{#str}}schema_name, local_servicemanager{{/str}}</label>
                        <input type="text" name="name" id="name" value="{{filter_name}}" class="form-control" placeholder="{{#str}}filter_name, local_servicemanager{{/str}}">
                    </div>
                    
                    <!-- Date from -->
                    <div class="mb-3">
                        <label for="datefrom_date">{{#str}}filter_date_from, local_servicemanager{{/str}}</label>
                        <input type="date" name="datefrom_date" id="datefrom_date" value="{{filter_datefrom}}" class="form-control">
                    </div>
                    
                    <!-- Date to -->
                    <div class="mb-3">
                        <label for="dateto_date">{{#str}}filter_date_to, local_servicemanager{{/str}}</label>
                        <input type="date" name="dateto_date" id="dateto_date" value="{{filter_dateto}}" class="form-control">
                    </div>
                    
                    <input type="hidden" name="datefrom" id="datefrom-timestamp" value="">
                    <input type="hidden" name="dateto" id="dateto-timestamp" value="">
                    
                    <div class="dropdown-divider"></div>
                    
                    <div class="d-flex justify-content-between">
                        <a href="?" class="btn btn-secondary">
                            <i class="fa fa-times mr-1"></i>{{#str}}filter_clear, local_servicemanager{{/str}}
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fa fa-check mr-1"></i>{{#str}}filter_apply, local_servicemanager{{/str}}
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    {{#can_manage}}
    <!-- Hidden form for bulk actions -->
    <form id="bulk-form" method="post" action="{{bulk_action_url}}" style="display: none;">
        <input type="hidden" name="sesskey" value="{{sesskey}}">
    </form>
    {{/can_manage}}

    {{#schemas_length}}
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="thead-light">
                <tr>
                    {{#can_manage}}
                    <th class="text-center" style="width: 40px;">
                        <input type="checkbox" id="select-all" class="bulk-checkbox-small" title="{{#str}}select_all, local_servicemanager{{/str}}">
                    </th>
                    {{/can_manage}}
                    <th>{{#str}}schema_name, local_servicemanager{{/str}}</th>
                    <th>{{#str}}schema_id, local_servicemanager{{/str}}</th>
                    <th>{{#str}}schema_version, local_servicemanager{{/str}}</th>
                    <th>{{#str}}schema_status, local_servicemanager{{/str}}</th>
                    <th>{{#str}}schema_modified, local_servicemanager{{/str}}</th>
                    <th class="text-right">{{#str}}actions{{/str}}</th>
                </tr>
            </thead>
            <tbody>
                {{#schemas}}
                <tr>
                    {{#can_manage}}
                    <td class="text-center">
                        <input type="checkbox" name="ids[]" value="{{id}}" form="bulk-form" class="bulk-checkbox-small schema-checkbox" data-enabled="{{#enabled}}1{{/enabled}}{{^enabled}}0{{/enabled}}">
                    </td>
                    {{/can_manage}}
                    <td>
                        <a href="{{view_url}}" class="font-weight-bold">{{name}}</a>
                        {{^enabled}}
                        <span class="badge badge-secondary ml-2">{{#str}}disabled, local_servicemanager{{/str}}</span>
                        {{/enabled}}
                    </td>
                    <td><code>{{schema_id}}</code></td>
                    <td>{{version}}</td>
                    <td>
                        <span class="badge {{status_class}}">
                            <i class="fa {{status_icon}} mr-1"></i>{{status_label}}
                        </span>
                    </td>
                    <td>{{timemodified}}</td>
                    <td class="text-right">
                        <div class="btn-group btn-group-sm">
                            <a href="{{view_url}}" class="btn btn-outline-primary" title="{{#str}}action_view, local_servicemanager{{/str}}">
                                <i class="fa fa-eye"></i>
                            </a>
                            {{#can_manage}}
                            <a href="{{edit_url}}" class="btn btn-outline-secondary" title="{{#str}}action_edit, local_servicemanager{{/str}}">
                                <i class="fa fa-edit"></i>
                            </a>
                            <a href="{{export_url}}" class="btn btn-outline-info" title="{{#str}}action_export, local_servicemanager{{/str}}">
                                <i class="fa fa-download"></i>
                            </a>

                            <a href="{{delete_url}}" class="btn btn-outline-danger" title="{{#str}}action_delete, local_servicemanager{{/str}}">
                                <i class="fa fa-trash"></i>
                            </a>
                            {{/can_manage}}
                        </div>
                    </td>
                </tr>
                {{/schemas}}
            </tbody>
        </table>
    </div>
    {{/schemas_length}}

    {{^schemas_length}}
    <div class="alert alert-info">
        <i class="fa fa-info-circle mr-2"></i>
        {{#has_filters}}
        {{#str}}no_schemas_filtered, local_servicemanager{{/str}}
        {{/has_filters}}
        {{^has_filters}}
        {{#str}}no_schemas, local_servicemanager{{/str}}
        <a href="{{documentation_url}}" class="ml-2 text-info">
            <i class="fa fa-book mr-1"></i>{{#str}}view_documentation, local_servicemanager{{/str}}
        </a>
        {{/has_filters}}
    </div>
    {{/schemas_length}}

    {{#has_pagination}}
    <!-- Pagination -->
    <nav aria-label="Schema pagination" class="servicemanager-pagination mt-4">
        <ul class="pagination justify-content-center">
            {{#pagination.show_first}}
            <li class="page-item">
                <a class="page-link" href="{{pagination.first_url}}" title="{{#str}}pagination_first, local_servicemanager{{/str}}">
                    <i class="fa fa-angle-double-left"></i>
                </a>
            </li>
            {{/pagination.show_first}}
            
            {{#pagination.show_previous}}
            <li class="page-item">
                <a class="page-link" href="{{pagination.previous_url}}" title="{{#str}}pagination_previous, local_servicemanager{{/str}}">
                    <i class="fa fa-angle-left"></i>
                </a>
            </li>
            {{/pagination.show_previous}}
            
            {{#pagination.show_start_dots}}
            <li class="page-item disabled"><span class="page-link">...</span></li>
            {{/pagination.show_start_dots}}
            
            {{#pagination.pages}}
            <li class="page-item {{#is_current}}active{{/is_current}}">
                <a class="page-link" href="{{page_url}}">{{page_num}}</a>
            </li>
            {{/pagination.pages}}
            
            {{#pagination.show_end_dots}}
            <li class="page-item disabled"><span class="page-link">...</span></li>
            {{/pagination.show_end_dots}}
            
            {{#pagination.show_last}}
            <li class="page-item">
                <a class="page-link" href="{{pagination.last_url}}">{{pagination.last_page_num}}</a>
            </li>
            {{/pagination.show_last}}
            
            {{#pagination.show_next}}
            <li class="page-item">
                <a class="page-link" href="{{pagination.next_url}}" title="{{#str}}pagination_next, local_servicemanager{{/str}}">
                    <i class="fa fa-angle-right"></i>
                </a>
            </li>
            {{/pagination.show_next}}
        </ul>
        <div class="text-center text-muted mt-2">
            {{#str}}pagination_page_info, local_servicemanager, {"current": "{{pagination.current_page}}", "total": "{{pagination.total_pages}}"}{{/str}}
        </div>
    </nav>
    {{/has_pagination}}

    {{#can_manage}}
    </form>
    {{/can_manage}}
</div>

{{#js}}
require(['jquery'], function($) {
    var $selectAll = $('#select-all');
    var $checkboxes = $('.schema-checkbox');
    var $bulkBar = $('#bulk-actions-bar');
    var $selectedCount = $('#selected-count');
    var $enableBtn = $('.bulk-btn-enable');
    var $disableBtn = $('.bulk-btn-disable');

    function updateBulkBar() {
        var $checked = $checkboxes.filter(':checked');
        var count = $checked.length;
        
        // Update count text.
        $selectedCount.text(count);

        if (count > 0) {
            $bulkBar.removeClass('d-none');
            $bulkBar.show(); // Ensure visibility.

            var hasDisabled = false;
            var hasEnabled = false;

            $checked.each(function() {
                var enabled = $(this).data('enabled');
                // Use loose comparison.
                if (enabled == 0) hasDisabled = true;
                if (enabled == 1) hasEnabled = true;
            });

            // Toggle buttons based on selection state.
            if (hasDisabled) {
                $enableBtn.show();
                $enableBtn.removeClass('d-none');
            } else {
                $enableBtn.hide();
            }

            if (hasEnabled) {
                $disableBtn.show();
                $disableBtn.removeClass('d-none');
            } else {
                $disableBtn.hide();
            }
        } else {
            $bulkBar.addClass('d-none');
            $bulkBar.hide();
        }
    }

    // Event listeners.
    $selectAll.on('change', function() {
        $checkboxes.prop('checked', this.checked);
        updateBulkBar();
    });

    $checkboxes.on('change', function() {
        var allChecked = $checkboxes.length > 0 && $checkboxes.length === $checkboxes.filter(':checked').length;
        $selectAll.prop('checked', allChecked);
        updateBulkBar();
    });

    // Handle date conversion for filters.
    $('#filter-form').on('submit', function(e) {
        var datefrom = $('#datefrom_date').val();
        var dateto = $('#dateto_date').val();
        
        if (datefrom) {
            $('#datefrom-timestamp').val(Math.floor(new Date(datefrom).getTime() / 1000));
        }
        if (dateto) {
            $('#dateto-timestamp').val(Math.floor(new Date(dateto).getTime() / 1000));
        }
        
        // Remove the date inputs from submission to avoid cluttering URL.
        $('#datefrom_date').prop('disabled', true);
        $('#dateto_date').prop('disabled', true);
    });
    
    // Initial check.
    updateBulkBar();
});
{{/js}}

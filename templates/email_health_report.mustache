{{!
    @template local_wsmanager/email_health_report

    Email template for health check reports.

    Context variables required for this template:
    * site_name - Name of the Moodle site
    * site_url - URL of the Moodle site
    * report_date - Formatted date
    * status_class - 'success', 'warning', or 'danger'
    * status_text - Overall status text
    * summary_text - Brief summary
    * has_issues - Boolean
    * issues - Array of issues
    * healthy_schemas - Array of healthy schemas (optional, if detailed report)
    * dashboard_url - Link to dashboard
}}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            line-height: 1.6;
            color: #333;
            background-color: #f5f5f5;
            margin: 0;
            padding: 0;
        }
        .email-container {
            max-width: 600px;
            margin: 0 auto;
            background-color: #ffffff;
            border: 1px solid #e0e0e0;
            border-radius: 4px;
            overflow: hidden;
        }
        .header {
            background-color: {{primary_color}};
            color: #ffffff;
            padding: 20px;
            text-align: center;
        }
        .header h1 {
            margin: 0;
            font-size: 24px;
            font-weight: normal;
        }
        .header img {
            max-height: 75px;
            max-width: 100%;
            height: auto;
        }
        .status-banner {
            padding: 15px;
            text-align: center;
            font-weight: bold;
            font-size: 18px;
            color: #ffffff;
        }
        .status-success { background-color: #28a745; }
        .status-warning { background-color: #ffc107; color: #212529; }
        .status-danger { background-color: #dc3545; }
        
        .content {
            padding: 20px;
        }
        .schema-item {
            border-bottom: 1px solid #eee;
            padding: 15px 0;
        }
        .schema-item:last-child {
            border-bottom: none;
        }
        .schema-name {
            font-weight: bold;
            font-size: 16px;
        }
        .schema-id {
            color: #666;
            font-size: 14px;
            font-family: monospace;
        }
        .issue-list {
            margin-top: 5px;
            padding-left: 20px;
            color: #d9534f;
        }
        .footer {
            background-color: #f8f9fa;
            border-top: 1px solid #e0e0e0;
            padding: 15px;
            text-align: center;
            font-size: 12px;
            color: #6c757d;
        }
        .btn {
            display: inline-block;
            padding: 10px 20px;
            margin-top: 15px;
            background-color: {{primary_color}};
            color: #ffffff;
            text-decoration: none;
            border-radius: 4px;
        }
        .badge {
            display: inline-block;
            padding: 0.25em 0.4em;
            font-size: 75%;
            font-weight: 700;
            line-height: 1;
            text-align: center;
            white-space: nowrap;
            vertical-align: baseline;
            border-radius: 0.25rem;
            color: #fff;
        }
        .badge-success { background-color: #28a745; }
        .badge-warning { background-color: #ffc107; color: #212529; }
        .badge-danger { background-color: #dc3545; }
    </style>
</head>
<body>
    <div class="email-container">
        <div class="header">
            {{#logo_url}}
            <img src="{{logo_url}}" alt="{{site_name}}">
            {{/logo_url}}
            {{^logo_url}}
            <h1>{{site_name}}</h1>
            {{/logo_url}}
        </div>
        
        <div class="status-banner status-{{status_class}}">
            {{status_text}}
        </div>

        <div class="content">
            <p><strong>{{report_date}}</strong></p>
            <p>{{summary_text}}</p>

            {{#has_issues}}
            <h3>{{#str}}issues, local_wsmanager{{/str}}</h3>
            {{#issues}}
            <div class="schema-item">
                <div class="schema-name">
                    {{name}} 
                    <span class="badge badge-{{status}}">{{status_label}}</span>
                </div>
                <div class="schema-id">{{schema_id}}</div>
                <ul class="issue-list">
                    {{#messages}}
                    <li>{{.}}</li>
                    {{/messages}}
                </ul>
                <a href="{{view_url}}" style="font-size: 12px;">{{#str}}view_schema, local_wsmanager{{/str}}</a>
            </div>
            {{/issues}}
            {{/has_issues}}

            {{#has_healthy}}
            <h3 style="margin-top: 20px;">{{#str}}status_healthy, local_wsmanager{{/str}}</h3>
            <ul>
                {{#healthy_schemas}}
                <li>
                    <strong>{{name}}</strong> <span style="color: #666;">({{schema_id}})</span>
                </li>
                {{/healthy_schemas}}
            </ul>
            {{/has_healthy}}

            <div style="text-align: center;">
                <a href="{{dashboard_url}}" class="btn">{{#str}}dashboard, local_wsmanager{{/str}}</a>
            </div>
        </div>

        <div class="footer">
            {{#logo_url}}
            <img src="{{logo_url}}" alt="{{site_name}}" style="max-height: 50px; margin-bottom: 10px;">
            {{/logo_url}}
            <p>{{#str}}email_footer, local_wsmanager{{/str}}</p>
            <a href="{{site_url}}" style="color: {{primary_color}};">{{site_url}}</a>
        </div>
    </div>
</body>
</html>
